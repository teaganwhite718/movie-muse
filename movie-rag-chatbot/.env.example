# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# TMDB API Key (required for data fetching)
# Get a free key at: https://www.themoviedb.org/settings/api
# Use the "API Read Access Token" (v4 auth), NOT the API key
TMDB_API_KEY=your-tmdb-read-access-token-here

# Embedding model (optional, defaults to text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# Chat model (optional, defaults to gpt-4o-mini)
CHAT_MODEL=gpt-4o-mini

# ChromaDB persistence directory (optional)
CHROMA_PERSIST_DIR=./vectordb/chroma_db

# Number of chunks to retrieve (optional, default 4)
TOP_K=4

# Conversation memory length (optional, default 8)
MEMORY_LENGTH=8
